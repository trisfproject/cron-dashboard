MYSQL_ROOT_PASSWORD=<mysql-root-password>
MYSQL_DATABASE=<mysql-database-name>
MYSQL_USER=<mysql-application-user>
MYSQL_PASSWORD=<mysql-application-password>

API_KEY=<cron-ingest-api-key>
AUTH_SECRET=<long-random-session-signing-secret>
AUTH_SESSION_TTL_SECONDS=43200
NYX_ADMIN_EMAIL=admin@example.com
NYX_ADMIN_PASSWORD=<initial-admin-password>
NYX_ADMIN_NAME=NYX Admin

NEXT_PUBLIC_APP_URL=https://cron-dashboard.example.com
INTERNAL_API_URL=http://backend:3000
NEXT_PUBLIC_APP_NAME=NYX Monitoring Platform
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_GIT_HASH=
NEXT_PUBLIC_APP_ENV=
NEXT_PUBLIC_BUILD_TIMESTAMP=

# Optional alert notification integrations. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional Telegram forum topic routing. Use TELEGRAM_TOPIC_ID or TELEGRAM_MESSAGE_THREAD_ID
# for a default topic, then override by severity when needed.
TELEGRAM_TOPIC_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_WARNING_TOPIC_ID=
TELEGRAM_CRITICAL_TOPIC_ID=
TELEGRAM_INFO_TOPIC_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
ALERT_EVALUATION_INTERVAL_MS=60000
