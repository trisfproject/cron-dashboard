# EXPERIMENTAL: This config is intended only for running MySQL with its data
# directory on NFS at /mnt/nfs/docker/cron-dashboard/mysql.
#
# MySQL on NFS can suffer from latency spikes, file locking issues, and possible
# data corruption if the network or NFS server becomes unstable. Prefer local
# disk or managed MySQL when moving beyond this controlled experiment.

[mysqld]
innodb_flush_log_at_trx_commit=2
sync_binlog=0
innodb_flush_method=O_DIRECT
